{
  "name": "ruleta-fortuna",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-manifests.cjs && vite build",
    "preview": "vite preview",
    "preview:prod": "npm run build && vite preview",
    "manifests": "node scripts/generate-manifests.cjs",
    "test": "npm run test:unit && npm run test:e2e && npm run test:e2e:native",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:native": "PLAYWRIGHT_NATIVE=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src tests playwright.config.js vite.config.js",
    "lint:fix": "eslint src tests playwright.config.js vite.config.js --fix",
    "cap:sync": "CAPACITOR=true npm run build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/screen-orientation": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.0",
    "canvas-confetti": "^1.9.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1",
    "sirv": "^3.0.1",
    "vitest": "^4.1.9",
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.62.0"
  }
}
